# Groq API key — habilita insights de arquitetura gerados por IA.
# Sem esta variavel, o app usa insights heuristicos (offline).
# Crie em https://console.groq.com/keys
GROQ_API_KEY=

# (opcional) Modelo Groq. Padrao: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# (opcional) Token do GitHub para repositorios privados e limites de taxa maiores.
GITHUB_TOKEN=
