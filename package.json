{
  "name": "codegraph",
  "version": "0.1.0",
  "description": "Visualizador de arquitetura de codigo com IA - gera um grafo interativo das dependencias de um repositorio (multi-linguagem) e aponta problemas de arquitetura usando IA.",
  "type": "module",
  "bin": {
    "codegraph": "dist/cli.js"
  },
  "files": [
    "dist",
    "viewer/dist"
  ],
  "scripts": {
    "build": "npm run build:viewer && npm run build:cli",
    "build:cli": "tsc -p tsconfig.json",
    "build:viewer": "cd viewer && vite build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "code",
    "graph",
    "architecture",
    "dependencies",
    "visualization",
    "ai",
    "react-flow"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dependency-cruiser": "^16.4.2",
    "fast-glob": "^3.3.2",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
